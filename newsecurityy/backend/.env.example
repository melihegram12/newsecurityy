# ZORUNLU: Production icin guclu bir anahtar uretilmeli
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_TIME_ZONE=Europe/Istanbul

DB_NAME=security
DB_USER=security
DB_PASSWORD=security
DB_HOST=localhost
DB_PORT=5432

CORS_ALLOWED_ORIGINS=

# Opsiyonel: lokal senkron API anahtari (X-Api-Key)
LOCAL_SYNC_API_KEY=

# ZORUNLU: bootstrap_users komutu icin panel sifreleri (env olmadan kullanici olusturulmaz)
APP_SECURITY_PASSWORD=
APP_HR_PASSWORD=
APP_DEVELOPER_PASSWORD=

# CORS izin verilen origin'ler (virgülle ayrilmis)
# Production ortaminda mutlaka belirtilmeli
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

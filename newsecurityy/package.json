{
  "name": "newsecurityy",
  "version": "1.0.12",
  "private": true,
  "description": "Offline-oncelikli guvenlik paneli (Electron + web).",
  "author": "ENGINME1",
  "main": "electron/main.js",
  "homepage": "./",
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@supabase/supabase-js": "^2.90.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "electron-updater": "^6.7.3",
    "lucide-react": "^0.555.0",
    "node-schedule": "^2.1.1",
    "nodemailer": "^7.0.12",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-scripts": "5.0.1",
    "recharts": "^3.6.0",
    "sql.js": "^1.13.0",
    "web-vitals": "^2.1.4",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "node scripts/build-with-time.js",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "api:map": "python scripts/api_business_mapper.py --root . --out docs/api-business-mapping",
    "email:smoke": "electron scripts/email_scheduler_smoke.js",
    "feature:smoke": "electron scripts/full_feature_smoke.js",
    "electron:dev": "concurrently \"cross-env BROWSER=none PORT=3001 npm start\" \"wait-on http://localhost:3001 && cross-env ELECTRON_DEV=true ELECTRON_RENDERER_URL=http://localhost:3001 electron .\"",
    "electron:build": "npm run build && electron-builder",
    "release:all": "powershell -ExecutionPolicy Bypass -File scripts/build-all.ps1",
    "release:all:install-apk": "powershell -ExecutionPolicy Bypass -File scripts/build-all.ps1 -InstallApk",
    "cap:sync": "npx cap sync",
    "android:open": "npx cap open android"
  },
  "build": {
    "appId": "com.malhotra.newsecurityy",
    "productName": "NewSecurityy Guvenlik Paneli",
    "compression": "store",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/logo512.png"
    },
    "nsis": {
      "artifactName": "NewSecurityy-Setup-${version}.exe"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "http://10.166.1.23:3001/updates/desktop/"
      }
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "autoprefixer": "^10.4.22",
    "baseline-browser-mapping": "^2.9.19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.5.6",
    "supabase": "^2.70.5",
    "tailwindcss": "^3.4.1",
    "wait-on": "^9.0.3"
  }
}
